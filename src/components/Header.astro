---
import { content, languages, localizePath, type Lang } from '../i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = content[lang];
const locales = Object.keys(languages) as Lang[];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line/60 bg-ink/70 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6" aria-label="Principal">
    <a href="#top" class="group font-mono text-sm tracking-tight text-fg">
      <span class="text-fg">vitmargan</span><span class="text-accent">.be</span>
    </a>

    <ul class="hidden items-center gap-8 lg:flex">
      {t.nav.map((item) => (
        <li>
          <a href={item.href} class="link-underline text-sm text-fg-dim transition-colors hover:text-fg">
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5 font-mono text-xs" aria-label="Language">
        {locales.map((l, i) => (
          <Fragment>
            {i > 0 && <span class="text-line" aria-hidden="true">·</span>}
            {l === lang ? (
              <span class="text-accent" aria-current="true">{l.toUpperCase()}</span>
            ) : (
              <a href={localizePath('/', l)} class="text-fg-dim transition-colors hover:text-accent" aria-label={languages[l]}>{l.toUpperCase()}</a>
            )}
          </Fragment>
        ))}
      </div>
      <span class="hidden h-4 w-px bg-line lg:block"></span>
      <a
        href="#contact"
        class="hidden rounded-full border border-accent/30 bg-accent/10 px-4 py-1.5 text-sm font-medium text-accent transition-colors hover:bg-accent hover:text-ink lg:inline-block"
      >
        {t.hero.ctaPrimary}
      </a>

      <button
        type="button"
        data-menu-toggle
        class="flex h-9 w-9 items-center justify-center rounded-md border border-line text-fg lg:hidden"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 5h14M2 9h14M2 13h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div data-menu-panel class="hidden border-t border-line/60 bg-ink/95 backdrop-blur-md lg:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col px-6 py-4">
      {t.nav.map((item) => (
        <li>
          <a href={item.href} data-menu-link class="block py-3 text-base text-fg-dim hover:text-fg">
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a href="#contact" data-menu-link class="mt-2 block rounded-full bg-accent px-4 py-2.5 text-center text-sm font-medium text-ink">
          {t.hero.ctaPrimary}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-menu-panel]');
  const close = () => {
    panel?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
  };
  toggle?.addEventListener('click', () => {
    const open = panel?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
  document.querySelectorAll('[data-menu-link]').forEach((l) => l.addEventListener('click', close));
</script>
