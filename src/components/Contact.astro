---
import { content, type Lang } from '../i18n/content';
import { siteConfig } from '../config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = content[lang].contact;

const cal = siteConfig.calLink;
const bookingHref = cal ? '#' : `mailto:${siteConfig.email}`;
---

<section id="contact" class="relative border-t border-line/50 py-24 md:py-32">
  <div class="relative mx-auto max-w-6xl px-6">
    <div class="grid grid-cols-1 gap-14 lg:grid-cols-2 lg:gap-20">
      <div>
        <div data-reveal class="mb-4 flex items-center gap-3 font-mono text-xs text-accent">
          <span>{c.index}</span>
          <span class="h-px w-8 bg-accent/40"></span>
          <span class="uppercase tracking-[0.2em] text-fg-dim">{c.kicker}</span>
        </div>
        <h2 data-reveal style="--i:1" class="text-4xl font-semibold text-fg sm:text-5xl">{c.title}</h2>
        <p data-reveal style="--i:2" class="mt-6 max-w-md text-lg leading-relaxed text-muted">{c.intro}</p>

        <div data-reveal style="--i:3" class="mt-10">
          <p class="font-mono text-xs uppercase tracking-widest text-muted">{c.orEmail}</p>
          <a href={`mailto:${c.email}`} class="link-underline mt-2 inline-block font-display text-2xl text-fg sm:text-3xl">
            {c.email}
          </a>
        </div>

        <ul data-reveal style="--i:4" class="mt-8 flex flex-wrap gap-3">
          {c.socials.map((s) => (
            <li>
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full border border-line bg-surface/50 px-4 py-2 text-sm text-fg-dim transition-colors hover:border-accent/50 hover:text-fg"
              >
                <span class="font-medium">{s.label}</span>
                <span class="font-mono text-xs text-muted">{s.handle}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Booking card -->
      <div data-reveal style="--i:2" class="relative overflow-hidden rounded-lg border border-line bg-surface/40 p-8">
        <div class="grid-lines pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
        <div class="relative">
          <div class="flex items-center gap-3">
            <div class="flex h-11 w-11 items-center justify-center rounded-lg border border-accent/30 bg-accent/10 text-accent">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="3" y="4" width="14" height="13" rx="2" stroke="currentColor" stroke-width="1.5" />
                <path d="M3 8h14M7 2v3M13 2v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="10" cy="12" r="1.5" fill="currentColor" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-fg">{c.bookingTitle}</h3>
              <p class="text-sm text-muted">{c.bookingDesc}</p>
            </div>
          </div>

          <a
            href={bookingHref}
            data-cal-link={cal || undefined}
            data-cal-config={cal ? '{"theme":"dark"}' : undefined}
            class="group mt-8 flex w-full items-center justify-center gap-2 rounded-full bg-accent px-6 py-3.5 text-sm font-semibold text-ink transition-transform hover:-translate-y-0.5"
          >
            {c.bookingCta}
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>

          <div class="mt-6 flex items-center gap-2 font-mono text-xs text-muted">
            <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
            Cal.com · 30 min · async-friendly
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{cal && (
  <script is:inline define:vars={{ cal, origin: siteConfig.calOrigin, brand: siteConfig.calBrandColor }}>
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal; let ar = arguments;
        if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement('script')).src = A; cal.loaded = true; }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1]; api.q = api.q || [];
          if (typeof namespace === 'string') { cal.ns[namespace] = cal.ns[namespace] || api; p(cal.ns[namespace], ar); p(cal, ['initNamespace', namespace]); }
          else p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, origin + '/embed/embed.js', 'init');
    Cal('init', { origin });
    Cal('ui', { theme: 'dark', hideEventTypeDetails: false, styles: { branding: { brandColor: brand } } });
  </script>
)}
