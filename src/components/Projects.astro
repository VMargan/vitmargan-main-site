---
import { content, type Lang } from '../i18n/content';
import SectionHeading from './SectionHeading.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = content[lang].projects;
---

<section id="projects" class="relative border-t border-line/50 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading index={p.index} kicker={p.kicker} title={p.title} intro={p.intro} />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
      {p.items.map((proj, idx) => (
        <article data-reveal style={`--i:${idx}`} class="card group flex flex-col rounded-lg border border-line bg-surface/40 p-7">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-xl font-semibold text-fg">{proj.name}</h3>
              <p class="mt-1 font-mono text-xs uppercase tracking-wide text-accent">{proj.tag}</p>
            </div>
            <span class="whitespace-nowrap font-mono text-xs text-muted">{proj.period}</span>
          </div>

          <p class="mt-4 text-[15px] leading-relaxed text-muted">{proj.summary}</p>

          <ul class="mt-4 space-y-2">
            {proj.highlights.map((hl) => (
              <li class="flex gap-3 text-sm text-fg-dim">
                <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent"></span>
                <span>{hl}</span>
              </li>
            ))}
          </ul>

          <ul class="mt-5 flex flex-wrap gap-2">
            {proj.stack.map((t) => (
              <li class="rounded border border-line bg-ink px-2.5 py-1 font-mono text-xs text-muted">{t}</li>
            ))}
          </ul>

          {proj.href && (
            <a
              href={proj.href}
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline mt-6 inline-flex w-fit items-center gap-2 text-sm font-medium text-fg"
            >
              {p.link}
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" class="text-accent" aria-hidden="true">
                <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
