---
import { content, type Lang } from '../i18n/content';
import SectionHeading from './SectionHeading.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = content[lang].services;
---

<section id="services" class="relative border-t border-line/50 py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading index={s.index} kicker={s.kicker} title={s.title} intro={s.intro} />

    <div class="grid grid-cols-1 gap-px overflow-hidden rounded-lg border border-line bg-line sm:grid-cols-2">
      {s.items.map((item, idx) => (
        <article
          data-reveal
          style={`--i:${idx}`}
          class="card group relative bg-ink p-8"
        >
          <div class="mb-6 flex items-baseline justify-between">
            <span class="font-mono text-sm text-accent">{item.num}</span>
            <span class="h-px flex-1 mx-4 bg-line"></span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="text-muted transition-all group-hover:text-accent group-hover:translate-x-0.5" aria-hidden="true">
              <path d="M4 14L14 4M14 4H6M14 4v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-fg">{item.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-muted">{item.desc}</p>
          <ul class="mt-6 flex flex-wrap gap-2">
            {item.tags.map((tag) => (
              <li class="rounded-full border border-line bg-surface px-3 py-1 font-mono text-xs text-fg-dim">{tag}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
