---
import { content, defaultLang, type Lang } from '../i18n/content';
import { siteConfig } from '../config';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const f = content[lang].footer;
const nav = content[lang].nav;
const year = new Date().getFullYear();
const changelogHref = lang === defaultLang ? '/changelog' : `/${lang}/changelog`;
---

<footer class="border-t border-line/60">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href="#top" class="font-mono text-sm">
          <span class="text-fg">vitmargan</span><span class="text-accent">.be</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-muted">{f.tagline}</p>
      </div>

      <nav class="flex flex-wrap gap-x-8 gap-y-3" aria-label="Pied de page">
        {nav.map((item) => (
          <a href={item.href} class="text-sm text-fg-dim transition-colors hover:text-fg">{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="rule-fade my-10"></div>

    <div class="flex flex-col-reverse items-start justify-between gap-4 sm:flex-row sm:items-center">
      <p class="font-mono text-xs text-muted">
        © {year} {f.legal}
      </p>
      <div class="flex items-center gap-6">
        <a href={changelogHref} class="font-mono text-xs text-muted transition-colors hover:text-accent">{f.changelog}</a>
        <span class="font-mono text-xs text-muted">{f.madeWith}</span>
        <a href="#top" class="group inline-flex items-center gap-1.5 font-mono text-xs text-fg-dim transition-colors hover:text-accent">
          {f.backToTop}
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="transition-transform group-hover:-translate-y-0.5" aria-hidden="true">
            <path d="M6 10V2M2.5 5.5L6 2l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
