---
import { getCollection } from 'astro:content';
import { content, defaultLang, languages, localizePath, type Lang } from '../i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const c = content[lang].changelog;

const homeHref = lang === defaultLang ? '/' : `/${lang}`;
const locales = Object.keys(languages) as Lang[];

const entries = (await getCollection('changelog')).sort((a, b) => {
  const pa = a.data.version.split('.').map(Number);
  const pb = b.data.version.split('.').map(Number);
  for (let i = 0; i < 3; i++) {
    const diff = (pb[i] || 0) - (pa[i] || 0);
    if (diff !== 0) return diff;
  }
  return b.data.date.getTime() - a.data.date.getTime();
});

const fmt = (d: Date) =>
  new Intl.DateTimeFormat(({ en: 'en-GB', fr: 'fr-BE', nl: 'nl-BE' } as const)[lang], {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(d);
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line/60 bg-ink/70 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-6">
    <a href={homeHref} class="font-mono text-sm">
      <span class="text-fg">vitmargan</span><span class="text-accent">.be</span>
    </a>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1.5 font-mono text-xs" aria-label="Language">
        {locales.map((l, i) => (
          <Fragment>
            {i > 0 && <span class="text-line" aria-hidden="true">·</span>}
            {l === lang ? (
              <span class="text-accent" aria-current="true">{l.toUpperCase()}</span>
            ) : (
              <a href={localizePath('/changelog', l)} class="text-fg-dim transition-colors hover:text-accent" aria-label={languages[l]}>{l.toUpperCase()}</a>
            )}
          </Fragment>
        ))}
      </div>
      <span class="h-4 w-px bg-line"></span>
      <a href={homeHref} class="link-underline inline-flex items-center gap-1.5 text-sm text-fg-dim transition-colors hover:text-fg">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M11 7H3M6.5 3.5L3 7l3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        {c.back}
      </a>
    </div>
  </div>
</header>

<main class="relative mx-auto max-w-3xl px-6 pt-32 pb-28">
  <div class="relative mb-16">
    <div class="mb-4 flex items-center gap-3 font-mono text-xs text-accent">
      <span>CHANGELOG</span>
      <span class="h-px w-8 bg-accent/40"></span>
    </div>
    <h1 class="text-4xl font-semibold text-fg sm:text-5xl">{c.title}</h1>
    <p class="mt-4 text-lg leading-relaxed text-muted">{c.intro}</p>
  </div>

  <ol class="relative ml-1 border-l border-line">
    {entries.map((e) => (
      <li class="relative ml-6 pb-12 last:pb-0">
        <span class="absolute -left-[31px] top-1.5 h-3 w-3 rounded-full border-2 border-accent bg-ink"></span>
        <div class="flex flex-wrap items-center gap-3">
          <span class="font-mono text-sm text-accent">v{e.data.version}</span>
          <span class="rounded-full border border-line px-2 py-0.5 font-mono text-[11px] uppercase tracking-wide text-fg-dim">
            {c.kinds[e.data.kind]}
          </span>
          <time class="font-mono text-xs text-muted">{fmt(e.data.date)}</time>
        </div>
        <h2 class="mt-3 text-xl font-semibold text-fg">{e.data.title[lang]}</h2>
        <ul class="mt-3 space-y-2">
          {e.data.notes[lang].map((n) => (
            <li class="flex gap-3 text-[15px] leading-relaxed text-fg-dim">
              <span class="mt-2 h-1 w-1 flex-none rounded-full bg-accent"></span>
              <span>{n}</span>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ol>
</main>
