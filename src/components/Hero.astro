---
import { content, type Lang } from '../i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = content[lang];
const h = t.hero;
---

<section id="top" class="relative overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-14 px-6 lg:grid-cols-[1.15fr_1fr]">
    <div>
      <p data-reveal style="--i:0" class="mb-6 inline-flex items-center gap-2 rounded-full border border-line bg-surface/60 px-3 py-1 font-mono text-xs text-fg-dim">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-70"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent"></span>
        </span>
        {h.eyebrow}
      </p>

      <h1 data-reveal style="--i:1" class="text-4xl font-semibold text-fg sm:text-5xl lg:text-6xl">
        {h.name}
      </h1>

      <p data-reveal style="--i:2" class="mt-3 font-mono text-lg text-accent transition-opacity duration-300" data-rotor data-words={JSON.stringify(h.roles)}>
        {h.roles[0]}
      </p>

      <p data-reveal style="--i:3" class="mt-6 max-w-xl text-balance text-xl leading-snug text-fg-dim sm:text-2xl">
        {h.title}
      </p>

      <p data-reveal style="--i:4" class="mt-5 max-w-xl text-base leading-relaxed text-muted">
        {h.lead}
      </p>

      <div data-reveal style="--i:5" class="mt-9 flex flex-wrap items-center gap-4">
        <a
          href="#contact"
          class="group inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-semibold text-ink transition-transform hover:-translate-y-0.5"
        >
          {h.ctaPrimary}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#stack" class="link-underline inline-flex items-center gap-2 py-3 text-sm font-medium text-fg">
          {h.ctaSecondary}
        </a>
      </div>
    </div>

    <!-- Terminal card -->
    <div data-reveal style="--i:6" class="relative">
      <div class="rounded-lg border border-line bg-ink-2/90 shadow-2xl shadow-black/40">
        <div class="flex items-center gap-2 border-b border-line px-4 py-3">
          <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
          <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
          <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
          <span class="ml-3 font-mono text-xs text-muted">{h.terminalTitle}</span>
        </div>
        <div class="space-y-1.5 p-5 font-mono text-[13px] leading-relaxed">
          {h.terminal.map((line) => (
            <p class={line.startsWith('$') ? 'text-fg' : line.startsWith('→') ? 'text-accent' : 'text-fg-dim'}>
              {line.startsWith('$') ? (<><span class="text-accent">$</span>{line.slice(1)}</>) : line}
            </p>
          ))}
          <p class="text-fg"><span class="text-accent">$</span> <span class="inline-block h-4 w-2 translate-y-0.5 animate-pulse bg-accent"></span></p>
        </div>
      </div>
    </div>
  </div>
</section>
