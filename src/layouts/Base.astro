---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/geist';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import { content, defaultLang, type Lang } from '../i18n/content';
import { siteConfig } from '../config';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  path?: string;
}

const { lang, title, description, path = '/' } = Astro.props;
const t = content[lang];
const site = Astro.site ?? new URL('https://vitmargan.be');

const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;

const localeUrl = (l: Lang) =>
  new URL(l === defaultLang ? path : `/${l}${path === '/' ? '' : path}`, site).href;
const canonical = localeUrl(lang);
const ogImage = new URL('/og.png', site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang="en" href={localeUrl('en')} />
    <link rel="alternate" hreflang="fr" href={localeUrl('fr')} />
    <link rel="alternate" hreflang="x-default" href={localeUrl(defaultLang)} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vincent Margan" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'fr' ? 'fr_BE' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vincent Margan — Freelance Software Engineer · .NET / Angular" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#070a13" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {siteConfig.umamiSrc && siteConfig.umamiWebsiteId && (
      <script is:inline defer src={siteConfig.umamiSrc} data-website-id={siteConfig.umamiWebsiteId}></script>
    )}
  </head>

  <body>
    <div class="sky" aria-hidden="true"></div>
    <div class="constellations" aria-hidden="true">
      <svg class="con con-dipper" viewBox="0 0 160 75">
        <circle cx="4" cy="40" r="1.3" /><circle cx="38" cy="30" r="1.5" /><circle cx="72" cy="23" r="1.3" /><circle cx="104" cy="19" r="1.3" /><circle cx="110" cy="55" r="1.3" /><circle cx="150" cy="60" r="1.4" /><circle cx="146" cy="20" r="1.5" />
      </svg>
      <svg class="con con-orion" viewBox="0 0 90 125">
        <circle cx="12" cy="8" r="1.5" /><circle cx="74" cy="2" r="1.4" /><circle cx="30" cy="54" r="1.3" /><circle cx="45" cy="60" r="1.3" /><circle cx="60" cy="66" r="1.3" /><circle cx="78" cy="116" r="1.5" /><circle cx="24" cy="112" r="1.3" />
      </svg>
      <svg class="con con-cas" viewBox="0 0 118 32">
        <circle cx="2" cy="22" r="1.3" /><circle cx="30" cy="2" r="1.4" /><circle cx="56" cy="26" r="1.3" /><circle cx="86" cy="4" r="1.4" /><circle cx="114" cy="28" r="1.3" />
      </svg>
      <svg class="con con-tri" viewBox="0 0 135 128">
        <circle cx="8" cy="10" r="1.5" /><circle cx="126" cy="4" r="1.4" /><circle cx="60" cy="120" r="1.4" />
      </svg>
    </div>
    <span class="shooting-star s1" aria-hidden="true"></span>
    <span class="shooting-star s2" aria-hidden="true"></span>
    <span class="shooting-star s3" aria-hidden="true"></span>
    <div class="aurora" aria-hidden="true"></div>
    <div class="grain-overlay" aria-hidden="true"></div>
    <slot />

    <script>
      // Scroll-reveal — progressive enhancement
      const els = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }

      // Rotating hero role
      const rotor = document.querySelector<HTMLElement>('[data-rotor]');
      if (rotor) {
        const words = JSON.parse(rotor.dataset.words || '[]') as string[];
        let i = 0;
        if (words.length > 1) {
          setInterval(() => {
            i = (i + 1) % words.length;
            rotor.style.opacity = '0';
            setTimeout(() => {
              rotor.textContent = words[i];
              rotor.style.opacity = '1';
            }, 260);
          }, 2600);
        }
      }
    </script>
  </body>
</html>
